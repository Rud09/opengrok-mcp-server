{
  "name": "opengrok-mcp-server",
  "displayName": "OpenGrok MCP Server",
  "description": "MCP server bridging OpenGrok search engine with AI for instant context across massive codebases",
  "version": "9.0.2",
  "mcpName": "io.github.IcyHot09/opengrok-mcp-server",
  "license": "PolyForm-Noncommercial-1.0.0",
  "publisher": "IcyHot09",
  "author": "Rudra Roy",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/IcyHot09/opengrok-mcp-server"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=22.0.0"
  },
  "categories": [
    "AI",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "opengrok",
    "code search",
    "copilot",
    "mcp",
    "model context protocol",
    "model-context-protocol",
    "ai",
    "github-copilot",
    "code-search"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "pricing": "Free",
  "activationEvents": [
    "onExtension:github.copilot-chat",
    "onCommand:opengrok-mcp.configure",
    "onCommand:opengrok-mcp.configureUI",
    "onCommand:opengrok-mcp.test",
    "onCommand:opengrok-mcp.statusMenu",
    "onCommand:opengrok-mcp.checkUpdate",
    "onCommand:opengrok-mcp.showLogs"
  ],
  "main": "./out/extension.js",
  "types": "./out/server/main.d.ts",
  "exports": {
    ".": {
      "types": "./out/server/main.d.ts",
      "default": "./out/server/main.js"
    }
  },
  "bin": {
    "opengrok-mcp": "./out/server/main.js",
    "opengrok-mcp-server": "./out/server/main.js"
  },
  "files": [
    "out/server/",
    "out/webview/",
    "images/",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "opengrok-mcp.configure",
        "title": "OpenGrok: Configure Credentials"
      },
      {
        "command": "opengrok-mcp.configureUI",
        "title": "OpenGrok: Open Configuration"
      },
      {
        "command": "opengrok-mcp.test",
        "title": "OpenGrok: Test Connection"
      },
      {
        "command": "opengrok-mcp.showLogs",
        "title": "OpenGrok: Show Server Logs"
      },
      {
        "command": "opengrok-mcp.statusMenu",
        "title": "OpenGrok: Status Menu"
      },
      {
        "command": "opengrok-mcp.checkUpdate",
        "title": "OpenGrok: Check for Updates"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "opengrok-mcp-server",
        "label": "OpenGrok Code Search"
      }
    ],
    "configuration": {
      "title": "OpenGrok MCP",
      "properties": {
        "opengrok-mcp.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenGrok server base URL",
          "order": 1
        },
        "opengrok-mcp.username": {
          "type": "string",
          "default": "",
          "description": "OpenGrok username (password stored securely in system keychain)",
          "order": 2
        },
        "opengrok-mcp.verifySsl": {
          "type": "boolean",
          "default": false,
          "description": "Verify SSL certificates (disable for self-signed/internal CA certs)",
          "order": 3
        },
        "opengrok-mcp.proxy": {
          "type": "string",
          "default": "",
          "description": "HTTP proxy URL (e.g., http://proxy.company.com:8080)",
          "order": 4
        },
        "opengrok-mcp.contextBudget": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "generous"
          ],
          "enumDescriptions": [
            "minimal (4 KB) — lowest token usage, fastest searches",
            "standard (8 KB) — balanced for most codebases",
            "generous (16 KB) — more context, larger token cost"
          ],
          "default": "minimal",
          "description": "Context budget mode — controls response size limits. Maps to OPENGROK_CONTEXT_BUDGET env var.",
          "order": 6
        },
        "opengrok-mcp.codeMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable Code Mode (2-tool API: opengrok_api + opengrok_execute). Significant token savings via JavaScript sandbox execution. Maps to OPENGROK_CODE_MODE env var.",
          "order": 7
        },
        "opengrok-mcp.memoryBankDir": {
          "type": "string",
          "default": "",
          "description": "Directory for Living Document memory bank files. Defaults to <workspace>/.opengrok/memory-bank/. Maps to OPENGROK_MEMORY_BANK_DIR env var.",
          "order": 8
        },
        "opengrok-mcp.compileDbPaths": {
          "type": "string",
          "default": "",
          "description": "Comma-separated paths to compile_commands.json files for C/C++ compile flag support. Leave blank for workspace auto-discovery. Maps to OPENGROK_LOCAL_COMPILE_DB_PATHS env var.",
          "order": 9,
          "scope": "window"
        },
        "opengrok-mcp.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Default OpenGrok project to scope searches to when none is specified. Maps to OPENGROK_DEFAULT_PROJECT env var.",
          "order": 10
        },
        "opengrok-mcp.responseFormatOverride": {
          "type": "string",
          "enum": [
            "",
            "markdown",
            "json"
          ],
          "enumDescriptions": [
            "Auto — let each tool choose the best format",
            "Force markdown for all tool responses",
            "Force JSON for all tool responses (programmatic use)"
          ],
          "default": "",
          "description": "Force all tool responses to a specific format (empty = auto). Maps to OPENGROK_RESPONSE_FORMAT_OVERRIDE env var.",
          "order": 11
        },
        "opengrok-mcp.apiVersion": {
          "type": "string",
          "enum": [
            "v1",
            "v2"
          ],
          "enumDescriptions": [
            "v1 — Default (OpenGrok 1.x)",
            "v2 — OpenGrok 2.x servers (explicit opt-in only)"
          ],
          "default": "v1",
          "description": "OpenGrok REST API version. Use v2 only if your server explicitly supports the v2 REST API.",
          "order": 12
        },
        "opengrok-mcp.enableElicitation": {
          "type": "boolean",
          "default": false,
          "description": "Enable project picker at opengrok_api startup and env.opengrok.elicit() in Code Mode sandbox (requires Claude Code v2.1.76+ or VS Code Copilot).",
          "order": 13
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "test": "vitest run",
    "test:sandbox": "npm run compile && vitest run --config vitest.sandbox.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint src/",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "vsix": "node scripts/build-vsix.js",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@iarna/toml": "^2.2.5",
    "@jitl/quickjs-ng-wasmfile-release-sync": "^0.31.0",
    "@modelcontextprotocol/sdk": "1.28.0",
    "@napi-rs/keyring": "^1.2.0",
    "@sebastianwessel/quickjs": "^3.0.1",
    "@toon-format/toon": "^2.1.0",
    "he": "^1.2.0",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "node-html-parser": "^6.1.0",
    "p-retry": "^7.0.0",
    "undici": "^7.24.2",
    "zod": "^4.0.0"
  },
  "overrides": {
    "test-exclude": "^8.0.0"
  },
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.1.4",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.1.4"
  }
}
